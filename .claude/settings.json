{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "VAULT_PATH": "./vault",
    "AGENTIC_OS_DB": "./.agentic-os/state.db"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(node dashboard/scripts/validate-skills.mjs)",
      "Read(./**)",
      "Edit(skills/**)",
      "Edit(vault/**)",
      "Write(skills/**)",
      "Write(vault/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
