# Path to your Claude Code data directory (defaults to ~/.claude)
CLAUDE_DIR=/home/YOUR_USERNAME/.claude

# Path to your Codex data directory (defaults to ~/.codex)
CODEX_DIR=/home/YOUR_USERNAME/.codex

# Flask server port
PORT=5050

# Frontend origin for CORS (dev only — production serves from the same port)
CORS_ORIGIN=http://localhost:5173

# Optional: Anthropic API key (only required for Managed Agents feature)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Anthropic API base URL
MANAGED_AGENTS_BASE_URL=https://api.anthropic.com
