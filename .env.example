# Copy to .env.local and fill in values.
# The dashboard reads these at startup.

# Full path to the claude CLI binary.
# On Windows it is usually bundled inside the VS Code extension — not on PATH.
# Find yours: Get-ChildItem "$env:USERPROFILE\.vscode\extensions\anthropic.claude-code*\resources\native-binary\claude.exe"
# On Mac/Linux it is typically on PATH already; leave this unset or set to just: claude
CLAUDE_BIN=C:\Users\YourName\.vscode\extensions\anthropic.claude-code-X.X.X-win32-x64\resources\native-binary\claude.exe

# Path to the Obsidian vault folder (default: ./vault relative to repo root)
VAULT_PATH=./vault

# Path to the SQLite state database (default: ./.agentic-os/state.db)
AGENTIC_OS_DB=./.agentic-os/state.db

# GitHub personal access token — needed by skills that use the GitHub MCP
# Scopes: repo (read-only is sufficient for most skills)
GITHUB_TOKEN=

# Notion integration token — needed by weekly-rollup and engagement-report skills
NOTION_API_KEY=

# Optional: override which Claude model the dashboard uses for headless runs
# Defaults to whatever `claude` CLI is configured to use
# CLAUDE_MODEL=claude-sonnet-4-6
